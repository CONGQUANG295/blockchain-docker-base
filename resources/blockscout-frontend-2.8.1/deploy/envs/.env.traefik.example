# Traefik integration for Blockscout frontend 2.8.1
#
# Used with blockscout-backend-11.2.1/docker-compose Traefik stack.
# Copy to backend compose envs:
#   cp deploy/envs/.env.traefik.example ../../blockscout-backend-11.2.1/docker-compose/envs/common-frontend.env

# Public explorer host (Traefik terminates TLS)
NEXT_PUBLIC_API_HOST=explorer.example.com
NEXT_PUBLIC_API_PROTOCOL=https
NEXT_PUBLIC_APP_HOST=explorer.example.com
NEXT_PUBLIC_APP_PROTOCOL=https
NEXT_PUBLIC_API_BASE_PATH=/
NEXT_PUBLIC_API_WEBSOCKET_PROTOCOL=wss

# Microservices on separate Traefik hosts
NEXT_PUBLIC_STATS_API_HOST=https://stats.example.com
NEXT_PUBLIC_VISUALIZE_API_HOST=https://visualize.example.com

NEXT_PUBLIC_NETWORK_NAME=DPOS Chain
NEXT_PUBLIC_NETWORK_SHORT_NAME=DPOS
NEXT_PUBLIC_NETWORK_ID=1337
NEXT_PUBLIC_NETWORK_CURRENCY_NAME=Coin
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=COIN
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=18
NEXT_PUBLIC_IS_TESTNET=false
NEXT_PUBLIC_HOMEPAGE_CHARTS=['daily_txs']
NEXT_PUBLIC_API_SPEC_URL=https://raw.githubusercontent.com/blockscout/blockscout-api-v2-swagger/main/swagger.yaml

# NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
