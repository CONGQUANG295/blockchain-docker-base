# Traefik / public domain configuration.
# Copy: cp envs/traefik.env.example envs/traefik.env

ACME_EMAIL=admin@example.com
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# Used in dynamic/blockscout-v11.yml (via generate-traefik-dynamic.sh)
NETWORK_TYPE=mainnet
EXPLORER_SERVER_NAME=explorer.example.com
STATS_SERVER_NAME=stats.example.com
VISUALIZE_SERVER_NAME=visualize.example.com

# Optional Traefik dashboard
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# JSON-RPC (OpenEthereum / Geth) — adjust for DPOS
ETHEREUM_JSONRPC_HTTP_URL=http://host.docker.internal:8545/
ETHEREUM_JSONRPC_TRACE_URL=http://host.docker.internal:8545/
ETHEREUM_JSONRPC_WS_URL=ws://host.docker.internal:8545/
CHAIN_ID=1337

# DPOS / OpenEthereum: uncomment
# ETHEREUM_JSONRPC_VARIANT=nethermind
# BLOCK_TRANSFORMER=clique
