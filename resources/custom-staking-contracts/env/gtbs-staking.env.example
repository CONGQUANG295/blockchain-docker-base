# GTBS custom staking — deploy defaults (owner can override Tier-1 on-chain after deploy)

# Validator
MAX_VALIDATORS=100
MIN_STAKE_TOKENS=100000
MAX_STAKE_TOKENS=300000000

# Delegator
MIN_DELEGATION_TOKENS=10000
MAX_DELEGATION_PER_WALLET_TOKENS=100000

# Economics
NET_APY_PERCENT=4

# Vesting / unbonding
ANNUAL_UNLOCK_CAP_TOKENS=500000
UNSTAKE_FEE_BPS=1000

# Time durations (converted to seconds at deploy)
DELEGATOR_LOCK_DAYS=180
ANNUAL_UNLOCK_PERIOD_DAYS=365
RELEASE_DELAY_DAYS=30

# Block timing (1s blocks for GTBS testnet)
BLOCK_TIME_SECONDS=1
BLOCKS_PER_YEAR=31536000
